# Docker Compose environment template for DEPLOY-002.
#
# HOW TO USE THIS FILE
#   1. Copy it to ".env" in the repository root:
#        cp .env.example .env
#   2. Copy Streamlit's auth secret template:
#        cp .streamlit/secrets.example.toml .streamlit/secrets.toml
#   3. Fill in the values below, then run:
#        docker compose up --build
#
# The real root ".env" file is git-ignored and must never be committed. This
# template is separate from Dependencies/.env.example, which remains the local
# non-container Python setup file.
# `docker compose config` is helpful for validation, but it prints interpolated
# environment values. Treat that output as sensitive once this file contains real
# credentials.

# --- Compose networking ------------------------------------------------------

# Host port for the Streamlit UI. The container always listens on 8501; this
# only controls the port on your laptop.
SCANNER_UI_PORT=8501

# Path to the Streamlit secrets file that Compose mounts read-only into the app
# container. Keep the real file local; it contains Google OIDC client secrets.
STREAMLIT_SECRETS_FILE=.streamlit/secrets.toml

# --- Local Postgres ----------------------------------------------------------

# These values create the local Compose Postgres database. Change the password
# before sharing a machine or using a long-lived environment. Postgres is not
# published to a host port by docker-compose.yml; only scanner-ui can reach it.
POSTGRES_DB=scanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=scanner_dev_password_change_me

# --- Required app settings ---------------------------------------------------

# Safe default for this Compose stack: it behaves like production locally.
APP_ENV=production
AUTH_REQUIRED=true
DATA_DIR=/data

# At least one admin or allowed email is required in production mode. Use the
# same email you will sign in with via Google OIDC.
ALLOWED_EMAILS=
ADMIN_EMAILS=you@example.com

# Dhan credentials are required by production settings validation. The examples
# below are placeholders; replace them with your real values before expecting
# scans to fetch market data.
DHAN_CLIENT_ID=replace-with-dhan-client-id
DHAN_ACCESS_TOKEN=replace-with-dhan-access-token

# --- Logging -----------------------------------------------------------------

# JSON logs are friendlier to Docker log collectors.
LOG_LEVEL=WARNING
LOG_FORMAT=json

# --- Optional AI/search features --------------------------------------------

# Required only for the 67 Ka Funda (AI) screener's Google snippets.
SERPAPI_API_KEY=

# Usually leave ANTHROPIC_API_KEY unset so the Claude Agent SDK uses your Claude
# subscription login instead of billing an API account.
ANTHROPIC_API_KEY=
CLAUDE_AGENT_MODEL=claude-sonnet-4-6
SCANNER_AGENT_FAST_MODE=0
SCANNER_AI_MAX_ATTEMPTS=2

# --- Optional data-fetch tuning ---------------------------------------------

# Keep the default sequential fetch path unless you deliberately want the
# PERF-001 parallel prefetch behavior.
SCANNER_DHAN_FETCH_WORKERS=1
SCANNER_DHAN_REQUEST_DELAY_SECONDS=0.5
SCANNER_DHAN_RATE_LIMIT_RETRY_DELAYS=2,5,10
SCANNER_SCREENER_IN_DELAY_SECONDS=1.5
SCANNER_FUNDAMENTALS_TTL_DAYS=30

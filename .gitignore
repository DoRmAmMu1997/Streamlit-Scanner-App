# Real credentials stay local. Use Dependencies/.env.example as the template.
.env
Dependencies/.env
Dependencies/all_instrument*.csv

# Generated scanner data can be refreshed/rebuilt, so keep it out of source.
data/cache/
data/universes/*
!data/universes/hemant_super_45.csv
!data/universes/hemant_good_45.csv
!data/universes/hemant_good_200.csv
!data/universes/hemant_super_good_200_union.csv

# Python/runtime noise.
__pycache__/
*.py[cod]
.pytest_cache/

# Streamlit local secrets should never be committed.
.streamlit/secrets.toml

# Virtual environments.
.venv/
venv/
env/

# Editor / IDE.
.vscode/
.idea/

# OS noise.
.DS_Store
Thumbs.db

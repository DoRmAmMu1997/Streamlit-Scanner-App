# DhanHQ credentials for the Streamlit Scanner App.
#
# HOW TO USE THIS FILE
#   1. Copy it to ".env" in this same folder:  cp .env.example .env
#   2. Fill in the values below.
#   3. Run:  python Dependencies/dhan_token_setup.py   (fills DHAN_ACCESS_TOKEN)
#
# The real ".env" file is git-ignored and must NEVER be committed.

# --- Required ---------------------------------------------------------------

# Your 10-digit Dhan client id.
DHAN_CLIENT_CODE=

# API Key + API Secret from web.dhan.co
#   (My Profile -> DhanHQ Trading APIs -> Generate API).
# Used by Dependencies/dhan_token_setup.py to mint the access token.
DHAN_API_KEY=
DHAN_API_SECRET=

# Leave this blank. `python Dependencies/dhan_token_setup.py` writes the
# 12-month access token here for you.
DHAN_ACCESS_TOKEN=

# --- Optional tuning (safe defaults are used if these are omitted) ----------

# Pause, in seconds, between Dhan history API calls (gentle on rate limits).
SCANNER_DHAN_REQUEST_DELAY_SECONDS=0.5

# Comma-separated backoff delays (seconds) for DH-904 rate-limit retries.
SCANNER_DHAN_RATE_LIMIT_RETRY_DELAYS=2,5,10

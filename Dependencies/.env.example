# DhanHQ credentials for the Streamlit Scanner App.
#
# HOW TO USE THIS FILE
#   1. Copy it to ".env" in this same folder:  cp .env.example .env
#   2. Fill in the values below.
#   3. Run:  python Dependencies/dhan_token_setup.py   (fills DHAN_ACCESS_TOKEN)
#
# The real ".env" file is git-ignored and must NEVER be committed.
# Beginner safety note: the shared backend redactor masks these configured
# values, plus common token/API-key/password shapes, before text reaches
# Streamlit errors, scan failure details, or configured logs. That is a safety
# net, not permission to paste real secrets into issues, screenshots, or PRs.

# --- Required for market-data downloads ------------------------------------

# Your 10-digit Dhan client id.
DHAN_CLIENT_ID=
# Legacy alias accepted by the app and token helper, kept here as a migration
# hint for older local .env files:
# DHAN_CLIENT_CODE=

# API Key + API Secret from web.dhan.co
#   (My Profile -> DhanHQ Trading APIs -> Generate API).
# Used by Dependencies/dhan_token_setup.py to mint the access token.
DHAN_API_KEY=
DHAN_API_SECRET=

# Leave this blank. `python Dependencies/dhan_token_setup.py` writes the
# 12-month access token here for you.
DHAN_ACCESS_TOKEN=

# --- Runtime settings (DEPLOY-004) ------------------------------------------

# development is safe for local work. Use production only on deployed hosts.
APP_ENV=development

# Local default is the repository's git-ignored data/ folder. Production should
# point DATA_DIR at a persistent disk or volume.
# DATA_DIR=C:\path\to\persistent\data

# Local default is sqlite:///data/scanner.db. Production must set DATABASE_URL,
# normally to Postgres or another managed database URL.
# DATABASE_URL=postgresql+psycopg://scanner:password@host:5432/scanner

# Standard Python logging level. Typos fail fast during settings parsing.
LOG_LEVEL=WARNING

# OBS-001 structured-log rendering. "auto" (default) emits machine-readable JSON
# in production and human-readable text in development; "json"/"text" force one.
LOG_FORMAT=auto

# Local default is false so developers can run the UI quickly. Production
# always requires auth; AUTH_REQUIRED=false is rejected when APP_ENV=production.
AUTH_REQUIRED=false

# Old aliases still work for compatibility, but new deploys should prefer the
# canonical names above.
# SCANNER_ENV=development
# SCANNER_DEBUG=1

# --- Optional tuning (safe defaults are used if these are omitted) ----------

# Pause, in seconds, between Dhan history API calls (gentle on rate limits).
SCANNER_DHAN_REQUEST_DELAY_SECONDS=0.5

# Comma-separated backoff delays (seconds) for DH-904 rate-limit retries.
SCANNER_DHAN_RATE_LIMIT_RETRY_DELAYS=2,5,10

# --- Access control (AUTH-002) ----------------------------------------------

# Comma-separated emails allowed to use the scanner once auth is enabled.
# Behavior when this list is EMPTY and auth is enabled:
#   * development (APP_ENV=development): every signed-in Google user is allowed.
#   * production  (APP_ENV=production):  startup fails unless ADMIN_EMAILS is set.
# When non-empty, only these emails (plus ADMIN_EMAILS) may access the app.
# Case and surrounding spaces don't matter:  you@gmail.com, Friend@Gmail.com
ALLOWED_EMAILS=

# Comma-separated emails treated as admins. Admins are ALWAYS allowed (even if
# absent from ALLOWED_EMAILS) and are flagged for future admin-only features.
ADMIN_EMAILS=

# --- Claude Agent SDK features ----------------------------------------------

# Check Fundamentals, Technical Analysis (AI), and 67 Ka Funda (AI) run on the Claude Agent SDK,
# authenticated through your Claude subscription via the bundled Claude CLI —
# there is NO API key to set here. One-time setup:
#   1. pip install claude-agent-sdk
#   2. Sign in once with the bundled Claude CLI (uses your Claude plan).
#   3. Make sure ANTHROPIC_API_KEY is NOT set anywhere this app can see it.
#      If it is set, the SDK bills your API account instead of your plan's
#      monthly Agent SDK credit.
#
# Optional API key path. The shared redactor masks this value from UI errors,
# scan failure details, and configured logs.
# ANTHROPIC_API_KEY=
#
# Optional: override the default Claude model used by the AI-backed features
# (claude-sonnet-4-6).
# CLAUDE_AGENT_MODEL=claude-sonnet-4-6

# Optional "fast mode" for AI agents (Check Fundamentals + Technical Analysis +
# 67 Ka Funda). When enabled, the agents disable extended thinking on each Claude
# Agent SDK call — lower latency, at a small cost to reasoning depth. OFF by
# default; set to 1/true/yes/on to enable.
# SCANNER_AGENT_FAST_MODE=1

# Optional pause, in seconds, between screener.in page fetches.
SCANNER_SCREENER_IN_DELAY_SECONDS=1.5

# Optional cache TTL (in days) for the parsed screener.in data per stock.
# Fundamentals refresh quarterly, so a long TTL is fine.
SCANNER_FUNDAMENTALS_TTL_DAYS=30

# --- 67 Ka Funda web research -----------------------------------------------

# Required only for the 67 Ka Funda (AI) screener's Google result snippets.
# The app uses SerpAPI instead of Google Custom Search JSON API.
SERPAPI_API_KEY=

# --- Daily scan notifications (ALERT-001) -----------------------------------

# After the headless daily scan finishes, an optional summary (status, counts,
# top-10 ranked results, failures, app link) can be sent to Telegram and/or
# email. Both channels are OPT-IN: each fires only when ALL of its values below
# are set, and a send failure never affects the scan. Leave a channel blank to
# disable it. TELEGRAM_BOT_TOKEN and SMTP_PASSWORD are masked by the redactor.

# Public base URL of the app, used for the "Open the app" link in the summary.
# APP_URL=https://your-scanner.example.com

# Telegram: create a bot via @BotFather for the token, and use your numeric chat
# id (message the bot, then read it from getUpdates).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email over SMTP (STARTTLS, e.g. port 587). SMTP_FROM defaults to SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# ALERT_EMAIL_TO=
